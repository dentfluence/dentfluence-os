{{-- ── Personalisation: apply stored preferences before first paint ── --}}
<script>
(function () {
    try {
        var p = JSON.parse(localStorage.getItem('df_prefs') || '{}');

        // Font
        var fonts = {
            'inter':   "'Inter', sans-serif",
            'nunito':  "'Nunito', sans-serif",
            'roboto':  "'Roboto', sans-serif",
            'poppins': "'Poppins', sans-serif",
        };
        var googleFonts = {
            'nunito':  'Nunito:wght@400;500;600;700',
            'roboto':  'Roboto:wght@400;500;700',
            'poppins': 'Poppins:wght@400;500;600;700',
        };
        if (p.font && fonts[p.font]) {
            document.documentElement.style.setProperty('--df-font-body', fonts[p.font]);
            // Inject Google Fonts link tag for fonts not already loaded (Inter is in the main <head> link)
            if (p.font !== 'inter' && googleFonts[p.font]) {
                var link = document.createElement('link');
                link.rel = 'stylesheet';
                link.href = 'https://fonts.googleapis.com/css2?family=' + googleFonts[p.font] + '&display=swap';
                document.head.appendChild(link);
            }
        }

        // Color scheme — rgb values for inline-style rgba() replacement
        var schemes = {
            'default': { primary:'#6a0f70', hover:'#530b5a', light:'#f9f3fa', border:'rgba(185,92,183,0.18)', rgb:'106,15,112',  borderRgb:'185,92,183'  },
            'blue':    { primary:'#1558b0', hover:'#0d3d80', light:'#f0f5ff', border:'rgba(21,88,176,0.18)',  rgb:'21,88,176',   borderRgb:'21,88,176'   },
            'teal':    { primary:'#0d7a6a', hover:'#095a4e', light:'#f0faf8', border:'rgba(13,122,106,0.18)', rgb:'13,122,106',  borderRgb:'13,122,106'  },
            'green':   { primary:'#1a7a45', hover:'#0f5030', light:'#f0faf4', border:'rgba(26,122,69,0.18)',  rgb:'26,122,69',   borderRgb:'26,122,69'   },
            'rose':    { primary:'#b52058', hover:'#821040', light:'#fff0f5', border:'rgba(181,32,88,0.18)',  rgb␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀